# ═══════════════════════════════════════════════════════════
# GourmetPOS ERP - Variables de Entorno
# Copia este archivo como .env y completa los valores
# ═══════════════════════════════════════════════════════════

# ── BASE DE DATOS ─────────────────────────────────────────────
# SQLite (por defecto, no requiere configuración)
DATABASE_URL=sqlite:///./gormet_pos.db

# PostgreSQL (producción)
# DATABASE_URL=postgresql://usuario:password@localhost/gormet_pos

# ── SERVIDOR ──────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
HOST=0.0.0.0
PORT=8000

# ── GOOGLE GEMINI IA ──────────────────────────────────────────
# Obtén tu API key en: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── WHATSAPP CLOUD API (META) ─────────────────────────────────
# Configura en: https://developers.facebook.com/
WA_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WA_PHONE_ID=123456789012345
WA_VERIFY_TOKEN=gormetpos2024

# ── SEGURIDAD ─────────────────────────────────────────────────
SECRET_KEY=gormetpos-secret-key-cambiar-en-produccion
ACCESS_TOKEN_EXPIRE_MINUTES=1440
